<Window x:Class="BatchImageCropper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BatchImageCropper"
        mc:Ignorable="d"
        Title="Batch Image Cropper" 
        Height="600" 
        Width="800"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop">

    <Window.Resources>
        <local:GridSizeConverter x:Key="GridSizeConverter"/>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Background="#F0F0F0">
            <Button Name="ExportButton" Content="Seçili Alanları Kırp ve Dışarı Aktar" 
                    Click="Export_Click" Margin="5,2" Background="#BFEFBB"/>
            <Button Name="ClearButton" Content="Fotoğrafları Kaldır" 
                    Click="Clear_Click" Margin="5,2"/>
            <Button Name="ClearCropButton" Content="Seçimi Temizle" 
                    Click="ClearCrop_Click" Margin="5,2"/>
            <Separator/>
            <CheckBox Name="PreserveMetadataCheckBox" Content="Meta Veriyi Koru" 
                      IsChecked="True" Margin="10,2"/>
            <CheckBox Name="SyncCheckBox" Content="Senkronize Et" 
                      IsChecked="False" Checked="Sync_Checked" Unchecked="Sync_Unchecked" Margin="10,2"/>
            <Separator/>
            <TextBlock Text="Dil: " VerticalAlignment="Center" Margin="5,0"/>
            <RadioButton Name="TurkishLanguageButton" Content="TR" IsChecked="True" 
                        Checked="TurkishLanguage_Checked" Margin="2" VerticalAlignment="Center"/>
            <RadioButton Name="EnglishLanguageButton" Content="EN" 
                        Checked="EnglishLanguage_Checked" Margin="2" VerticalAlignment="Center"/>
            <Separator/>
            <Button Name="AboutButton" Content="Hakkında" 
                    Click="About_Click" Margin="5,2"/>
            <Separator/>
            <TextBlock Text="Thumbnail: " VerticalAlignment="Center" Margin="5,0"/>
            <Slider Name="ThumbnailSizeSlider" 
                    Minimum="1" Maximum="100" Value="25" 
                    Width="100" Margin="5,2"
                    TickFrequency="10" TickPlacement="BottomRight"
                    ValueChanged="ThumbnailSize_ValueChanged"/>
            <TextBlock Name="ThumbnailSizeLabel" Text="25%" VerticalAlignment="Center" Margin="5,0" Width="40"/>
        </ToolBar>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#E0E0E0">
            <StatusBarItem>
                <TextBlock Name="StatusText" Text="Resimleri sürükleyip buraya bırakın"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content -->
        <Grid>
            <!-- Drop Zone (shown when no images) -->
            <Border Name="DropZone" 
                    Background="#F8F8F8" 
                    BorderBrush="#DDD" 
                    BorderThickness="2" 
                    CornerRadius="10"
                    Margin="20">
                <Grid>
                    <TextBlock Text="📁 Resimleri buraya sürükleyin" 
                               FontSize="24" 
                               Foreground="#888" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Image List (shown when images are loaded) -->
            <ScrollViewer Name="ImageScrollViewer" 
                        Visibility="Collapsed"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                <ItemsControl Name="ImageGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Name="ImageStackPanel" Margin="10" Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDD" BorderThickness="1" 
                                    Background="White" Margin="5" CornerRadius="3">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                                </Border.Effect>
                                <Grid Width="{Binding ElementName=ImageScrollViewer, Path=ActualWidth}"
                                      Margin="5">

                                    <!-- Image -->
                                    <Image Source="{Binding Thumbnail}" 
                                           Stretch="Uniform" 
                                           Margin="2"
                                           Width="{Binding DisplayWidth}"
                                           Height="{Binding DisplayHeight}"
                                           Name="DisplayImage"/>

                                    <!-- Crop Canvas -->
                                    <Canvas Background="Transparent"
                                            Name="CropCanvas"
                                            MouseLeftButtonDown="Crop_Start"
                                            MouseMove="Crop_Move"
                                            MouseLeftButtonUp="Crop_End"
                                            Margin="2"
                                            Width="{Binding DisplayWidth}"
                                            Height="{Binding DisplayHeight}">

                                        <!-- Crop Rectangle -->
                                        <Rectangle Name="CropRectangle"
                                                  Stroke="Red" 
                                                  StrokeThickness="2" 
                                                  Fill="Transparent"
                                                  Canvas.Left="{Binding CropX}"
                                                  Canvas.Top="{Binding CropY}"
                                                  Width="{Binding CropWidth}"
                                                  Height="{Binding CropHeight}"/>

                                    </Canvas>

                                    <!-- Image Info -->
                                    <Border Background="#80000000" CornerRadius="0,0,3,0" 
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                                           Margin="2" Padding="5,2">
                                        <TextBlock Text="{Binding FileName}" 
                                                  Foreground="White" FontSize="10" 
                                                  FontWeight="Bold">
                                            <TextBlock.ToolTip>
                                                <ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Path}"/>
                                                        <TextBlock Text="{Binding FormattedFileSize}"/>
                                                        <TextBlock Text="{Binding FormattedCreationTime}"/>
                                                    </StackPanel>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </Border>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
